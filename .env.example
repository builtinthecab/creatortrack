# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to client) — used only in Vercel API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID — create a recurring $19.99/month price in the Stripe dashboard
STRIPE_PRICE_ID=price_...

# ─── App URL ─────────────────────────────────────────────────────────────────
# Your production URL (used for OAuth redirects and sync callbacks)
APP_URL=https://your-app.vercel.app

# ─── Cron auth ───────────────────────────────────────────────────────────────
# Any random secret — paste into Vercel env AND add as a Vercel Cron secret
# Generate one with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ─── Gumroad OAuth ───────────────────────────────────────────────────────────
# Create an OAuth application at gumroad.com/settings/developer
# Set the redirect URI to: https://your-app.vercel.app/api/oauth/gumroad-callback
GUMROAD_CLIENT_ID=your-gumroad-client-id
GUMROAD_CLIENT_SECRET=your-gumroad-client-secret

# ─── Google / YouTube OAuth ──────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Enable: YouTube Data API v3, YouTube Analytics API
# Set the redirect URI to: https://your-app.vercel.app/api/oauth/youtube-callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
