# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to client) — used only in Vercel API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID — create a recurring $19.99/month price in the Stripe dashboard
STRIPE_PRICE_ID=price_...

# ─── App URL ─────────────────────────────────────────────────────────────────
# Your production URL (used for Stripe success/cancel redirects)
APP_URL=https://your-app.vercel.app
